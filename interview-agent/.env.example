# LLM Configuration
# Default provider name (must match a key in LLM_PROVIDERS)
LLM_DEFAULT_PROVIDER=local

# Providers JSON: {"name": {"base_url": "...", "api_key": "...", "model": "..."}}
# Each provider is an OpenAI-compatible API endpoint
LLM_PROVIDERS={"local":{"base_url":"http://localhost:11434/v1","api_key":"","model":"qwen2.5:7b"},"deepseek":{"base_url":"https://api.deepseek.com/v1","api_key":"your-deepseek-key","model":"deepseek-chat"}}

# MCP Server Configuration
# Comma-separated list of MCP server URLs (HTTP transport)
MCP_SERVER_URLS=

# Or stdio transport (uncomment and configure)
# MCP_STDIO_COMMAND=python
# MCP_STDIO_ARGS=path/to/server.py

# Auth Configuration
# MUST change the secret key in production!
AUTH_SECRET_KEY=change-me-in-production
AUTH_TOKEN_EXPIRE_HOURS=24
AUTH_COOKIE_SECURE=false
# Comma-separated invite codes for registration. Leave empty to disable invite check.
AUTH_INVITE_CODE=

# VectorDB runs as an internal Docker service in production.
VECTORDB_BASE_URL=http://localhost:9000
VECTORDB_ADMIN_TOKEN=change-me-too

# Optional: only needed when VectorDB must generate profiles from raw experiences.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat

# Server Configuration
# Comma-separated CORS allowed origins
SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Deployment Configuration (for deploy.sh)
SSL_DOMAIN=your-domain.com
SSL_EMAIL=admin@your-domain.com

# Optional build acceleration. Mainland China servers can use a mirror such as:
# PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PYPI_INDEX_URL=https://pypi.org/simple
UV_VERSION=0.11.16
APP_UID=10001
APP_GID=10001
